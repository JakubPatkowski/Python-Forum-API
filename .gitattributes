# Normalize line endings across platforms.
# Git stores text with LF; checks out native on each OS.
* text=auto eol=lf

# Windows-only scripts keep CRLF so they run correctly under PowerShell.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Explicit LF for code / config (avoids the phantom CRLF diffs).
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

# Binary assets — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.pdf   binary
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.lock  -diff
