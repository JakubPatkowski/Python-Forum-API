# syntax=docker/dockerfile:1.7
# ---------------------------------------------------------------------------
# Multi-stage build using `uv` from Astral.
#
# Stage 1 (`builder`):  resolves and installs dependencies into a private
#                       virtualenv at /app/.venv. Uses uv's bytecode-compile
#                       pass so cold-start latency is minimal.
# Stage 2 (`runtime`):  copies just the venv and the application code into a
#                       slim Python image. No uv, no compilers in the final
#                       layer → smaller, attack-surface reduced.
# ---------------------------------------------------------------------------

ARG PYTHON_VERSION=3.12

# =========================================================================
# Stage 1 — builder
# =========================================================================
FROM ghcr.io/astral-sh/uv:python${PYTHON_VERSION}-bookworm-slim AS builder

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# 1) Install dependencies (cached as long as the lockfile does not change).
#    uv.lock is generated by `uv lock` on the developer machine.
COPY pyproject.toml uv.lock* ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev

# 2) Install the project itself.
COPY . .
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

# =========================================================================
# Stage 2 — runtime
# =========================================================================
FROM python:${PYTHON_VERSION}-slim AS runtime

# libmagic is required by python-magic (used in the files module, phase 3).
RUN apt-get update \
 && apt-get install -y --no-install-recommends libmagic1 \
 && rm -rf /var/lib/apt/lists/*

# Non-root user — k8s securityContext can pin runAsUser to 1000.
RUN groupadd --system --gid 1000 app \
 && useradd --system --uid 1000 --gid app --create-home --shell /bin/bash app

WORKDIR /app

# Copy the prebuilt virtualenv and the application code.
COPY --from=builder --chown=app:app /app/.venv /app/.venv
COPY --from=builder --chown=app:app /app /app

# Ensure the venv binaries (uvicorn, alembic, ...) are on PATH.
ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Uploads directory — bound to a PVC in k8s.
RUN mkdir -p /app/uploads && chown -R app:app /app/uploads
VOLUME ["/app/uploads"]

USER app

EXPOSE 8000

# Production default; docker-compose overrides with --reload for local dev.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
