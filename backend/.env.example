# Example environment variables for local development.
# Copy to .env and adjust as needed. The real .env is gitignored.

# --- Database --------------------------------------------------------------
# Driver: psycopg3 — must match the package installed by uv (see pyproject.toml).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/forum_wedkarskie

# --- JWT -------------------------------------------------------------------
# Generate a strong key for non-dev use:
#   openssl rand -hex 64
SECRET_KEY=dev-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App -------------------------------------------------------------------
APP_NAME=Forum Wędkarskie API
DEBUG=true

# --- Uploads / files -------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=26214400
MAX_COMMENT_DEPTH=5

# --- MinIO / object storage ------------------------------------------------
# MINIO_ENDPOINT  — seen by the BACKEND (in docker-compose: "minio:9000").
# MINIO_PUBLIC_ENDPOINT — host put inside presigned URLs; must be reachable by
#   the BROWSER (in docker-compose: "localhost:9000"). Empty → MINIO_ENDPOINT.
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=forum-files
MINIO_SECURE=false
# Presigned URL lifetimes (seconds) and orphan retention (hours).
FILE_DOWNLOAD_URL_TTL_SECONDS=3600
FILE_UPLOAD_URL_TTL_SECONDS=900
FILE_ORPHAN_RETENTION_HOURS=24
